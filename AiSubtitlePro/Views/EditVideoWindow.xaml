<Window x:Class="AiSubtitlePro.Views.EditVideoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewmodels="clr-namespace:AiSubtitlePro.ViewModels"
        xmlns:converters="clr-namespace:AiSubtitlePro.Converters"
        mc:Ignorable="d"
        Title="Edit Video"
        Width="1200"
        Height="900"
        MinWidth="800"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}">

    <Window.Resources>
        <converters:InverseBoolConverter x:Key="InvertedBooleanConverter" />
        <converters:DoubleFormatConverter x:Key="DoubleFormatConverter" />
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- Header -->
        <Border DockPanel.Dock="Top" Padding="20" Background="{DynamicResource MaterialDesignPaper}" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Edit Video" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="Apply advanced video transformations using FFmpeg" Foreground="Gray" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer DockPanel.Dock="Top" Foreground="#F5F5F5">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="400" />
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Settings and Log -->
                <StackPanel Grid.Column="0">
                    <!-- File Selection Section -->
                    <Border CornerRadius="6" BorderBrush="#3F3F46" BorderThickness="1" Background="#1A1A1A" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Input/Output" FontSize="14" FontWeight="SemiBold" />
                            
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <TextBox Grid.Column="0" 
                                         Text="{Binding InputVideoPath}" 
                                         Foreground="Gray" 
                                         IsReadOnly="True"
                                         Padding="10,8"
                                         VerticalAlignment="Center"
                                         materialDesign:HintAssist.Hint="Input video file"
                                         Background="#2A2A2A" />
                                
                                <Button Grid.Column="1" 
                                        Command="{Binding SelectInputVideoCommand}"
                                        Margin="8,0,0,0"
                                        Padding="16,8"
                                        Content="Browse"
                                        Background="#3F3F46"
                                        Foreground="White" />
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <TextBox Grid.Column="0" 
                                         Text="{Binding OutputVideoPath}" 
                                         Padding="10,8"
                                         VerticalAlignment="Center"
                                         materialDesign:HintAssist.Hint="Output video file"
                                         Background="#2A2A2A" />
                                
                                <Button Grid.Column="1" 
                                        Command="{Binding SelectOutputVideoCommand}"
                                        Margin="8,0,0,0"
                                        Padding="16,8"
                                        Content="Browse"
                                        Background="#3F3F46"
                                        Foreground="White" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Processing Steps -->
                    <Border CornerRadius="6" BorderBrush="#3F3F46" BorderThickness="1" Background="#1A1A1A" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Text="Processing Steps" FontSize="14" FontWeight="SemiBold" />
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,0">
                                    <Button Command="{Binding EnableAllStepsCommand}"
                                            Padding="10,4"
                                            Content="Enable All"
                                            FontSize="11"
                                            Background="#4CAF50"
                                            Foreground="White"
                                            Margin="0,0,8,0" />
                                    <Button Command="{Binding DisableAllStepsCommand}"
                                            Padding="10,4"
                                            Content="Disable All"
                                            FontSize="11"
                                            Background="#FF9800"
                                            Foreground="White" />
                                </StackPanel>
                            </Grid>

                            <StackPanel>
                                <CheckBox IsChecked="{Binding RemoveMetadata}" Content="① Remove Metadata" FontSize="12" Margin="0,0,0,8" />
                                
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0" IsChecked="{Binding ChangeAspectRatio}" Content="② Change Aspect Ratio" FontSize="12" />
                                    <ComboBox Grid.Column="1" 
                                              ItemsSource="{Binding AspectRatioOptions}"
                                              SelectedItem="{Binding AspectRatio}"
                                              Margin="12,0,0,0"
                                              Background="#2A2A2A"
                                              Foreground="White"
                                              Padding="8" />
                                </Grid>

                                <CheckBox IsChecked="{Binding HorizontalFlip}" Content="③ Horizontal Flip" FontSize="12" Margin="0,0,0,8" />

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0" IsChecked="{Binding AdjustSpeed}" Content="④ Adjust Speed" FontSize="12" />
                                    <Slider Grid.Column="1" 
                                            Value="{Binding SpeedMultiplier}"
                                            Minimum="0.5"
                                            Maximum="2.0"
                                            Margin="12,0,8,0"
                                            VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" 
                                               Text="{Binding SpeedMultiplier, Converter={StaticResource DoubleFormatConverter}, ConverterParameter='F2x'}"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <CheckBox IsChecked="{Binding AdjustColors}" Content="⑤ Adjust Colors" FontSize="12" Margin="0,0,0,8" />
                                <StackPanel Margin="24,8,0,8">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="50" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Brightness:" FontSize="11" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" 
                                                Value="{Binding Brightness}"
                                                Minimum="-0.5"
                                                Maximum="0.5"
                                                Margin="8,0,8,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding Brightness, Converter={StaticResource DoubleFormatConverter}, ConverterParameter='F2'}" FontSize="11" VerticalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="50" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Contrast:" FontSize="11" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" 
                                                Value="{Binding Contrast}"
                                                Minimum="0.5"
                                                Maximum="2.0"
                                                Margin="8,0,8,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding Contrast, Converter={StaticResource DoubleFormatConverter}, ConverterParameter='F2'}" FontSize="11" VerticalAlignment="Center" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="50" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Saturation:" FontSize="11" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" 
                                                Value="{Binding Saturation}"
                                                Minimum="0.5"
                                                Maximum="2.0"
                                                Margin="8,0,8,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding Saturation, Converter={StaticResource DoubleFormatConverter}, ConverterParameter='F2'}" FontSize="11" VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0" IsChecked="{Binding ShiftPitch}" Content="⑥ Pitch Shift (semitones)" FontSize="12" />
                                    <Slider Grid.Column="1" 
                                            Value="{Binding PitchShift}"
                                            Minimum="-12"
                                            Maximum="12"
                                            Margin="12,0,8,0"
                                            VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" 
                                               Text="{Binding PitchShift, Converter={StaticResource DoubleFormatConverter}, ConverterParameter='F1'}" 
                                               TextAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0" IsChecked="{Binding ReplaceMusic}" Content="⑦ Replace Background Music" FontSize="12" />
                                    <Button Grid.Column="1" 
                                            Command="{Binding SelectMusicFileCommand}"
                                            Padding="10,4"
                                            Content="Select"
                                            FontSize="11"
                                            Background="#3F3F46"
                                            Foreground="White" />
                                </Grid>
                                <TextBlock Text="{Binding MusicFilePath}" 
                                           Foreground="Gray" 
                                           FontSize="10"
                                           Margin="24,0,0,8"
                                           TextTrimming="CharacterEllipsis" />

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0" IsChecked="{Binding ReencodeVideo}" Content="⑧ Re-encode Video" FontSize="12" />
                                    <ComboBox Grid.Column="1" 
                                              ItemsSource="{Binding CodecOptions}"
                                              SelectedItem="{Binding Codec}"
                                              Margin="12,0,0,0"
                                              Background="#2A2A2A"
                                              Foreground="White"
                                              Padding="8" />
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0" IsChecked="{Binding AddWatermark}" Content="⑨ Add Watermark" FontSize="12" />
                                </Grid>
                                <TextBox Margin="24,4,0,0"
                                         Text="{Binding WatermarkText}"
                                         Padding="8"
                                         materialDesign:HintAssist.Hint="Watermark text"
                                         Background="#2A2A2A" />
                            </StackPanel>

                            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                <Button Command="{Binding ResetSettingsCommand}"
                                        Padding="12,8"
                                        Content="Reset to Defaults"
                                        FontSize="12"
                                        Background="#FF9800"
                                        Foreground="White" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Panel: Progress and Log -->
                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                    <!-- Progress Section -->
                    <Border CornerRadius="6" BorderBrush="#3F3F46" BorderThickness="1" Background="#1A1A1A" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Processing Status" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />
                            
                            <ProgressBar 
                                Value="{Binding ProgressValue}"
                                Height="20"
                                Foreground="#4CAF50"
                                Background="#2A2A2A"
                                Margin="0,0,0,12" />
                            
                            <TextBlock 
                                Text="{Binding ProgressText}"
                                Foreground="White"
                                TextAlignment="Center"
                                FontSize="12"
                                TextWrapping="Wrap"
                                Margin="0,0,0,12" />

                            <StackPanel>
                                <Button 
                                    Command="{Binding ProcessVideoCommand}"
                                    IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertedBooleanConverter}}"
                                    Padding="12,16"
                                    Content="▶ Start Processing"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    Margin="0,0,0,8" />
                                
                                <Button 
                                    Command="{Binding CancelProcessingCommand}"
                                    IsEnabled="{Binding IsProcessing}"
                                    Padding="12,10"
                                    Content="⏹ Cancel"
                                    FontSize="12"
                                    Background="#FF5252"
                                    Foreground="White"
                                    Margin="0,0,0,8" />
                                
                                <Button 
                                    Command="{Binding PreviewVideoCommand}"
                                    Padding="12,10"
                                    Content="▶ Preview Video"
                                    FontSize="12"
                                    Background="#2196F3"
                                    Foreground="White" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Log Section -->
                    <Border CornerRadius="6" BorderBrush="#3F3F46" BorderThickness="1" Background="#1A1A1A" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Text="Processing Log" FontSize="12" FontWeight="SemiBold" />
                                <Button Grid.Column="1" 
                                        Command="{Binding ClearLogCommand}"
                                        Padding="8,4"
                                        Content="Clear"
                                        FontSize="10"
                                        Background="#3F3F46"
                                        Foreground="White" />
                            </Grid>

                            <ListBox 
                                ItemsSource="{Binding LogMessages}"
                                Background="#0A0A0A"
                                Foreground="#E0E0E0"
                                BorderBrush="#3F3F46"
                                BorderThickness="1"
                                Padding="8"
                                Height="280"
                                FontSize="10"
                                FontFamily="Courier New"
                                VirtualizingStackPanel.IsVirtualizing="False"
                                ScrollViewer.CanContentScroll="False">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0,2" />
                                        <Setter Property="Background" Value="Transparent" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
